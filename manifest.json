{
  "manifest_version": 3,
  "name": "TradingView Replay Session Jumper",
  "description": "Local helper to jump TradingView Bar Replay to the next configured session time.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "debugger", "tabs"],
  "host_permissions": ["https://www.tradingview.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tradingview.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "tv-replay-next": {
      "suggested_key": { "default": "Alt+Shift+N" },
      "description": "Jump to next replay session"
    },
    "tv-replay-prev": {
      "suggested_key": { "default": "Alt+Shift+P" },
      "description": "Jump to previous replay session"
    },
    "tv-replay-init": {
      "suggested_key": { "default": "Alt+Shift+I" },
      "description": "Set current replay session date"
    },
    "tv-replay-toggle": {
      "suggested_key": { "default": "Alt+Shift+H" },
      "description": "Show or hide replay jump overlay"
    }
  }
}
